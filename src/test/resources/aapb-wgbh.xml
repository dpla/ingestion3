  <pbcoreTitle titleType='Series'>Say Brother</pbcoreTitle>
  <pbcoreTitle titleType='Program'>Black Women and the ERA</pbcoreTitle>
  <pbcoreTitle titleType='Episode Number'>611</pbcoreTitle>
  <pbcoreSubject>Discrimination</pbcoreSubject>
  <pbcoreSubject>African Americans Massachusetts</pbcoreSubject>
