# Copy to .env and fill in values. Do not commit .env.

# Slack Incoming Webhook URL for #tech-alerts (create in Slack: Settings → Integrations → Incoming Webhooks)
SLACK_WEBHOOK=your_webhook_url_here

# Java 11+ required (java.net.http used in HttpUtils). Java 19 is known to work.
# Find available JDKs: /usr/libexec/java_home -V (macOS)
JAVA_HOME=/path/to/java-11-or-newer
